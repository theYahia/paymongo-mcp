# Your PayMongo SECRET key. Test keys start with the test prefix, live keys
# with the live prefix. Get it at https://dashboard.paymongo.com/developers
PAYMONGO_SECRET_KEY=

# Safety guard. Money-moving tools (create_payment, create_refund,
# create_payment_intent, create_source, create_checkout, create_link,
# create_payment_method) are REFUSED when the key above is a LIVE key
# (sk_live_) unless this is set to exactly "true".
PAYMONGO_ALLOW_LIVE=false

# NOTE: the webhook signing secret used by `verify_webhook_signature` is NOT an
# env var. It is the per-webhook secret (whsk_...) returned when you create a
# webhook, and you pass it to the tool as an argument.
